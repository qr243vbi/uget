<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.ugetdm.uGet</id>
  <metadata_license>CC0</metadata_license>
  <project_license>LGPL-2.1-or-later</project_license>
  <name>uGet</name>
  <summary>Download manager</summary>
  <description>
    <p>uGet is a lightweight yet powerful open source download manager.</p>
    <p>Some highlights of uGet:</p>
    <ul>
      <li>Multi-connection downloads</li>
      <li>Batch downloads</li>
      <li>Downloads queue with categories</li>
      <li>Pause and resume downloads</li>
      <li>Scheduler</li>
      <li>aria2 integration for BitTorrent and metalink</li>
      <li>Multiple protocols (HTTP, HTTPS, FTP, SFTP)</li>
      <li>System tray integration</li>
      <li>Translated into 36 languages</li>
      <li>Keyboard shortcuts</li>
      <li>Download history</li>
      <li>After completion actions</li>
      <li>FTP login and anonymous FTP</li>
      <li>Folder auto-creation</li>
    </ul>
  </description>
  <developer_name>Ozgur As</developer_name>
  <url type="bugtracker">https://github.com/ozgur-as/uget/issues</url>
  <url type="homepage">https://github.com/ozgur-as/uget</url>
  <url type="vcs-browser">https://github.com/ozgur-as/uget</url>
  <kudos>
    <kudo>ModernToolkit</kudo>
    <kudo>HiDpiIcon</kudo>
    <kudo>HighContrast</kudo>
  </kudos>
  <provides>
    <binary>uget-gtk</binary>
  </provides>
  <launchable type="desktop-id">uget-gtk.desktop</launchable>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="2.3.0" date="2026-03-02">
      <description>
        <ul>
          <li>Migrated entire UI from GTK3 to GTK4</li>
          <li>Migrated build system from Autotools to Meson</li>
          <li>Full Wayland support</li>
          <li>System tray via StatusNotifierItem (no GTK3 dependency)</li>
          <li>Modern OpenSSL and libcurl APIs</li>
          <li>Added install targets and i18n locale compilation</li>
          <li>Fixed all compiler and runtime warnings</li>
        </ul>
      </description>
    </release>
    <release version="2.2.3" date="2020-01-01">
      <description>
        <ul>
          <li>Add parser for YouTube recently changed field.</li>
        </ul>
      </description>
    </release>
    <release version="2.2.2" date="2019-05-20">
      <description>
        <ul>
          <li>Use quicksort to sort downloads.</li>
          <li>Backup torrent and metalink files.</li>
          <li>Curl plug-in: handle duplicate files with double extensions.</li>
        </ul>
      </description>
    </release>
    <release version="2.2.1" date="2018-03-08">
      <description>
        <ul>
          <li>Reduce memory usage.</li>
          <li>Adjust speed limit independently without enabling global speed limit.</li>
          <li>Fix: Can't get 1080p video from YouTube.</li>
        </ul>
      </description>
    </release>
    <release version="2.2.0" date="2018-01-06">
      <description>
        <ul>
          <li>Mega plug-in: create new plug-in for MEGA site.</li>
          <li>All plug-in: avoid crash if plug-in failed to start.</li>
          <li>Fix: some category/status doesn't refresh its download list.</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
